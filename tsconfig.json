{
    "compilerOptions": {
        "target": "es6",
        "module": "es6",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "moduleResolution": "bundler",
        "types": [
            "office-js"
        ],
        "isolatedModules": true,
        "useDefineForClassFields": true,
        "strict": true,
        "strictNullChecks": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "allowJs": true,
        "checkJs": true,
    },
    "include": [
        "web/src/**/*.ts",
        "web/src/**/*.js",
    ],
}